# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
#
# MongoDB Atlas connection string.
# Get it from: https://cloud.mongodb.com
#   → Your cluster → Connect → Drivers → copy the connection string
#   Replace <username>, <password>, and <dbname> with your Atlas credentials.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Firebase Admin SDK service account key, base64-encoded.
# Generate from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Encode it:     base64 -w0 < path/to/serviceAccountKey.json
# Paste the single-line output here.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Comma-separated list of admin email addresses (Google accounts).
# These users can manage questions via the admin API (create, update, delete).
ADMIN_EMAILS=admin@example.com
